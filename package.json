{
  "name": "vector-search-demo",
  "version": "0.1.0",
  "description": "End-to-end semantic vector search demo: embed, index, query, evaluate.",
  "type": "module",
  "bin": {
    "commander": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=.env --watch src/server.mjs",
    "start": "node --env-file=.env src/server.mjs",
    "typecheck": "tsc --noEmit",
    "eval": "node src/eval/index.js",
    "milvus:up": "docker compose up -d",
    "milvus:down": "docker compose down"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "@zilliz/milvus2-sdk-node": "^3.0.3",
    "commander": "^15.0.0",
    "fastify": "^5.8.5",
    "mammoth": "^1.12.0",
    "pg": "^8.21.0",
    "pgvector": "^0.3.0",
    "sharp": "^0.32.6",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.6.2"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.100"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
