# Server port (default: 8000)
PORT=8000

# Data backend: "mock" (file-backed collection.json, no Milvus needed — the
# default) or "milvus" (live Milvus). Mock lets you check the UI without
# starting the docker-compose Milvus stack. When unset, the presence of
# MILVUS_HOST below selects Milvus (legacy behavior).
DATA_BACKEND=mock

# Milvus gRPC host/port (used when DATA_BACKEND=milvus). MILVUS_HOST/MILVUS_PORT
# take precedence over MILVUS_ADDRESS.
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# Milvus gRPC address (default: localhost:19530)
MILVUS_ADDRESS=localhost:19530

# Milvus collection name (default: documents)
COLLECTION_NAME=documents

# Embedding model (default: Xenova/all-MiniLM-L6-v2)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Embedding dimension (default: 384)
DIM=384

# Postgres + pgvector (used when DATA_BACKEND=postgres or for direct pg client use)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vectordb
POSTGRES_USER=vectoruser
POSTGRES_PASSWORD=vectorpass
