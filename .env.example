# Deployment environment shown in the UI header (local hides the badge; prd → [PRD], uat → [UAT]).
ENV=local

# Server port (default: 8000)
PORT=8000

# Data backend: "mock" (file-backed collection.json, the default), "milvus"
# (live Milvus), or "postgres" (Postgres/pgvector). DB_BACKEND is the canonical
# selector — usePostgres() reads DB_BACKEND only; DATA_BACKEND is a legacy alias
# honoured for mock/milvus. When both are unset, the presence of MILVUS_HOST
# below selects Milvus (legacy behavior).
DB_BACKEND=mock

# Milvus gRPC host/port (used when DATA_BACKEND=milvus). MILVUS_HOST/MILVUS_PORT
# take precedence over MILVUS_ADDRESS.
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# Milvus gRPC address (default: localhost:19530)
MILVUS_ADDRESS=localhost:19530

# Milvus collection name (default: documents)
COLLECTION_NAME=documents

# Embedding model (default: Xenova/all-MiniLM-L6-v2)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Embedding dimension (default: 384)
DIM=384

# Postgres + pgvector (used when DB_BACKEND=postgres).
# DATABASE_URL is the primary connection string — both PgVectorStore and the
# pg_client health probe read it first. Setting DATABASE_URL alone is sufficient
# for all operations. The POSTGRES_* vars below are optional: they serve as the
# fallback in pg_client (when DATABASE_URL is absent) and as docker-compose
# service defaults for local development. Operators running against a managed
# Postgres instance (e.g. Neon, Supabase) only need DATABASE_URL.
DATABASE_URL=postgresql://vectoruser:vectorpass@localhost:5432/vectordb
# Optional — only needed when DATABASE_URL is unset (fallback for pg_client)
# or to match docker-compose service environment variables.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vectordb
POSTGRES_USER=vectoruser
POSTGRES_PASSWORD=vectorpass
